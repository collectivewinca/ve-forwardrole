# ── ve-forwardrole .env ───────────────────────────────────────────────────────
# Copy to .env, fill what you have. Everything is optional — each missing key
# just disables one capability (noted per line). `setup.sh` prints a checklist.

# Signing details for cover letters (optional)
YOUR_NAME=
YOUR_EMAIL=

# ── The brain — set ANY ONE of these ─────────────────────────────────────────
# Powers auto-triage, LinkedIn-PDF parsing, keyword expansion, outreach drafts.
# Resolution order: LLM_BASE_URL → ANTHROPIC_API_KEY → OPENAI_API_KEY →
# exe.dev link-local gateway (exe.dev VMs only, no key needed).
# Without any of them the pipeline still discovers roles; you triage by hand.

# Option A — Anthropic (recommended; console.anthropic.com)
ANTHROPIC_API_KEY=

# Option B — OpenAI (platform.openai.com); uses gpt-4o-mini
OPENAI_API_KEY=

# Option C — any OpenAI-compatible gateway: OpenRouter, Ollama, Groq, LM Studio,
# Gemini's compat endpoint, Vercel AI Gateway... LLM_MODEL is required here.
#   OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1  LLM_MODEL=anthropic/claude-haiku-4.5
#   Ollama:     LLM_BASE_URL=http://localhost:11434/v1     LLM_MODEL=llama3.1  (no key)
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# ── Discovery sources ─────────────────────────────────────────────────────────
# ATS job boards (Greenhouse/Lever/Ashby/SmartRecruiters) need NO key — they
# poll public JSON using your per-profile companies.yaml watchlist.

# Apify (apify.com) — adds LinkedIn job search. Paid usage (~cents/run).
APIFY_TOKEN=
APIFY_LINKEDIN_ACTOR=curious_coder~linkedin-jobs-scraper

# Exa (exa.ai, free tier) — adds neural job search + warm-path discovery
# (alumni + ex-colleagues) + JD fit scoring.
EXA_API_KEY=

# ── Notifications (optional) ──────────────────────────────────────────────────
# Telegram bot from @BotFather; chat id = message your bot, then check
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Dashboard / infra (only if you run the web dashboard) ─────────────────────
# Where the data root lives (defaults to ~/ve-work of the user running the app)
VE_WORK_ROOT=
POCKETBASE_URL=http://127.0.0.1:8090
# user@host for pi/deploy-app.sh (build happens on your laptop, rsync to here)
VE_WORK_VM=

# ── Shareable published page (optional, here.now) ────────────────────────────
HERENOW_PUBLISH_SCRIPT=
HERENOW_API_KEY=

# ── Cron PRs (optional) ───────────────────────────────────────────────────────
# Where the discovery cron opens PRs. Defaults to your `origin` remote; only
# set this to override. Requires the `gh` CLI to be authenticated.
GITHUB_REPO=
# Operator profile name — gets the cron PR link in their Telegram ping
OPERATOR_PROFILE=
